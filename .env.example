# ============================================================
# CENYCA — Variables de entorno
# Copia este archivo como .env.local y llena los valores
# NUNCA subas .env.local a GitHub
# ============================================================

# ------------------------------------------------------------
# SANITY CMS
# Obtén estos valores en: https://sanity.io/manage
# ------------------------------------------------------------

# ID del proyecto Sanity (visible, se puede exponer al cliente)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset a usar (generalmente "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Versión de la API de Sanity
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-08

# Token de Sanity con permisos de lectura (para ISR / revalidación)
# Genera uno en: Sanity Manage > API > Tokens
# IMPORTANTE: Este token es privado, no usar NEXT_PUBLIC_
SANITY_API_READ_TOKEN=

# ------------------------------------------------------------
# STUDIO + ADMIN — Basic auth
# - /studio: ya NO usa basic auth (login Sanity controla acceso).
# - /admin/*: panel interno de leads. Reusa estas credenciales.
# Si STUDIO_USERNAME/PASSWORD no están definidas, /admin queda
# bloqueado por defecto (fail-closed).
# ------------------------------------------------------------

STUDIO_USERNAME=admin
STUDIO_PASSWORD=

# ------------------------------------------------------------
# EMMA (Novai) — CRM de prospección
# Server-only desde la migración a /api/leads. La key ya NO viaja
# al bundle del navegador: vive solo en el servidor y se usa
# desde app/api/leads/route.ts.
# Rotación = actualizar EMMA_API_KEY en Vercel (Production +
# Preview + Development) y redeploy.
# ------------------------------------------------------------

EMMA_API_KEY=

# ------------------------------------------------------------
# NEON POSTGRES — Backup de leads
# Inyectada automáticamente por la integración de Vercel Storage
# (Neon). En local: copia el connection string desde Vercel >
# Storage > Cenyca-Leads-Web > .env.local.
# Se usa server-only (lib/db.ts) — nunca debe llevar NEXT_PUBLIC_.
# ------------------------------------------------------------

DATABASE_URL=

# ------------------------------------------------------------
# ENTORNO
# ------------------------------------------------------------

# URL pública del sitio (sin slash al final)
# Ejemplo: https://www.cenyca.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
